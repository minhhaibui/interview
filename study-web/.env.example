# Mẫu cấu hình Firebase. Copy file này thành `.env` rồi điền giá trị thật của bạn.
#   cp study-web/.env.example study-web/.env
# Lấy giá trị tại: Firebase Console → ⚙️ Project settings → Your apps → SDK config.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
